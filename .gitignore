# Python
__pycache__/
*.py[cod]
*.pyo
*.pyd
*.so
*.egg-info/
.eggs/
.env
.venv
venv/

# Django
*.log
local_settings.py
db.sqlite3
media/
staticfiles/

# Environment
.env.*
.env

# OS / Editor
.DS_Store
.idea/
.vscode/

# Test / coverage
.coverage
htmlcov/

# Node (nếu có frontend)
node_modules/

*/tests/images/

# Visual snapshots — entire folder is generated by tests/snapshot_*.py
# Only README.md is tracked so devs know what the folder is for
render/*
!render/README.md

# ── Flutter (semir-phone/) ───────────────────────────────────────────────────
semir-phone/.dart_tool/
semir-phone/.flutter-plugins
semir-phone/.flutter-plugins-dependencies
semir-phone/.packages
semir-phone/build/
semir-phone/.fvm/
semir-phone/pubspec.lock

# Flutter golden test outputs — only README tracked
semir-phone/render/*
!semir-phone/render/README.md

# Store assets screenshots (large binaries, regenerated locally)
semir-phone/store-assets/screenshots/

# Fastlane sensitive files
semir-phone/fastlane/report.xml
semir-phone/fastlane/screenshots/
semir-phone/fastlane/Preview.html

# iOS build artifacts
semir-phone/ios/Pods/
semir-phone/ios/.symlinks/
semir-phone/ios/Flutter/Flutter.framework/
semir-phone/ios/Flutter/Flutter.podspec

# Android build artifacts
semir-phone/android/.gradle/
semir-phone/android/captures/
semir-phone/android/local.properties
semir-phone/android/key.properties

# TLS certificate assets — never commit
semir-phone/assets/certs/*.pem
semir-phone/assets/certs/*.crt