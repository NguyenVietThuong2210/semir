default_platform(:ios)

# ─────────────────────────────────────────────────────────────────────────────
# iOS lanes
# ─────────────────────────────────────────────────────────────────────────────
platform :ios do
  desc "Upload to TestFlight (internal beta)"
  lane :beta do
    increment_build_number(xcodeproj: "ios/Runner.xcodeproj")
    build_app(
      scheme: "Runner",
      workspace: "ios/Runner.xcworkspace",
      export_method: "app-store",
      output_directory: "build/ios/ipa",
      output_name: "SandBDashboard.ipa",
    )
    upload_to_testflight(
      skip_waiting_for_build_processing: true,
    )
  end

  desc "Submit build for App Store review"
  lane :release do
    build_app(
      scheme: "Runner",
      workspace: "ios/Runner.xcworkspace",
      export_method: "app-store",
      output_directory: "build/ios/ipa",
      output_name: "SandBDashboard.ipa",
    )
    deliver(
      submit_for_review: true,
      automatic_release: false,
      force: true,
    )
  end
end

# ─────────────────────────────────────────────────────────────────────────────
# Android lanes
# ─────────────────────────────────────────────────────────────────────────────
platform :android do
  desc "Build signed AAB and upload to Play Store"
  lane :beta do |options|
    track = options[:track] || "internal"
    gradle(
      task: "bundle",
      build_type: "Release",
      project_dir: "android/",
      properties: {
        "android.injected.signing.store.file"     => ENV["KEYSTORE_PATH"],
        "android.injected.signing.store.password" => ENV["KEYSTORE_PASS"],
        "android.injected.signing.key.alias"      => ENV["KEY_ALIAS"],
        "android.injected.signing.key.password"   => ENV["KEY_PASS"],
      },
    )
    upload_to_play_store(
      track: track,
      aab: "android/app/build/outputs/bundle/release/app-release.aab",
      json_key_data: ENV["PLAY_STORE_JSON_KEY"],
      release_status: "draft",
    )
  end
end
